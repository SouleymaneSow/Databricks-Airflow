# Airflow security keys (generate your own)
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=

# Databricks connection (required by databricks_default)
# Use workspace host without protocol, e.g. adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# Databricks Job configuration
AUTO_INSURANCE_DATABRICKS_JOB_ID=<your job id>
AUTO_INSURANCE_DAG_SCHEDULE=@daily
AUTO_INSURANCE_DAG_TIMEZONE=Europe/Paris
